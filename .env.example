# Environment variables for CoinTracker.
#
# Copy to `.env` and fill in values. `.env` is gitignored — never commit real
# secrets. Load it into your shell before running the app or tests:
#
#     set -a; source .env; set +a
#
# This project uses STRICT configuration: the app refuses to boot if any of the
# "Required in all environments" values below is missing (no in-repo defaults).

# ── Required in ALL environments (dev, test, prod) ─────────────────────────
# Generate the two crypto values with `mix phx.gen.secret` (and `… 32` for the salt).
SECRET_KEY_BASE=
LIVE_VIEW_SIGNING_SALT=

# Public deployment identity (shown in the UI and outgoing email).
APP_NAME=CoinTracker
SENDER_EMAIL=noreply@example.com
SUPPORT_EMAIL=support@example.com
ADMIN_NOTIFICATION_EMAIL=admin@example.com

# ── Required for the app to FUNCTION (data providers) ──────────────────────
# Without COINSCANX_API_KEY the signal poller errors on every fetch and the
# /signals page stays empty — the app boots but has no product. Without
# COINGECKO_API_KEY the CoinGecko client falls back to the anonymous endpoint
# which 429s under real use and breaks live price enrichment. Get these set
# before expecting any data to flow.
COINSCANX_API_KEY=
COINGECKO_API_KEY=

# ── Optional integrations (features degrade gracefully if unset in dev) ────
# With TELEGRAM_BOT_TOKEN empty you'll see periodic 404 lines in the logs from
# the bot polling Telegram — expected; all non-Telegram features keep working.
TELEGRAM_BOT_TOKEN=

# ── Required in PRODUCTION only ────────────────────────────────────────────
DATABASE_URL=
PHX_HOST=
RESEND_API_KEY=
# PORT=8080
# POOL_SIZE=10
# ECTO_IPV6=false
# DNS_CLUSTER_QUERY=
